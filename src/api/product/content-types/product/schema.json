{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "product"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "quantity": {
      "type": "integer"
    },
    "price": {
      "type": "decimal"
    },
    "subtotal": {
      "type": "decimal"
    },
    "order_date": {
      "type": "date"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "cancelled"
      ]
    },
    "order": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::order.order",
      "inversedBy": "product"
    }
  }
}
